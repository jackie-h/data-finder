// ── Milestoning helpers ───────────────────────────────────────────────────────
{% if need_proc or need_bd %}

fn parse_dt(s: &str) -> Result<chrono::NaiveDateTime> {
    chrono::DateTime::parse_from_rfc3339(s)
        .map(|dt| dt.naive_utc())
        .or_else(|_| chrono::NaiveDateTime::parse_from_str(s, "%Y-%m-%dT%H:%M:%S"))
        .map_err(|e| async_graphql::Error::new(e.to_string()))
}

fn parse_date(s: &str) -> Result<chrono::NaiveDate> {
    chrono::NaiveDate::parse_from_str(s, "%Y-%m-%d")
        .map_err(|e| async_graphql::Error::new(e.to_string()))
}
{% endif %}

{% if need_proc %}
async fn query_processing<T>(
    pool: &PgPool,
    base: &str,
    as_of: Option<&str>,
    in_col: &str,
    out_col: &str,
) -> Result<Vec<T>>
where
    T: for<'r> sqlx::FromRow<'r, sqlx::postgres::PgRow> + Send + Unpin,
{
    match as_of {
        Some(ts) => {
            let dt = parse_dt(ts)?;
            let sql = format!(
                "{base} WHERE {in_col} <= $1 AND ({out_col} IS NULL OR {out_col} > $1)"
            );
            sqlx::query_as::<_, T>(&sql).bind(dt).fetch_all(pool).await
        }
        None => sqlx::query_as::<_, T>(base).fetch_all(pool).await,
    }
    .map_err(|e| async_graphql::Error::new(e.to_string()))
}
{% endif %}

{% if need_bd %}
async fn query_business_date<T>(
    pool: &PgPool,
    base: &str,
    business_date: Option<&str>,
    date_col: &str,
) -> Result<Vec<T>>
where
    T: for<'r> sqlx::FromRow<'r, sqlx::postgres::PgRow> + Send + Unpin,
{
    match business_date {
        Some(bd) => {
            let date = parse_date(bd)?;
            let sql  = format!("{base} WHERE {date_col} = $1");
            sqlx::query_as::<_, T>(&sql).bind(date).fetch_all(pool).await
        }
        None => sqlx::query_as::<_, T>(base).fetch_all(pool).await,
    }
    .map_err(|e| async_graphql::Error::new(e.to_string()))
}

async fn query_bitemporal<T>(
    pool: &PgPool,
    base: &str,
    business_date: Option<&str>,
    date_col: &str,
    as_of: Option<&str>,
    in_col: &str,
    out_col: &str,
) -> Result<Vec<T>>
where
    T: for<'r> sqlx::FromRow<'r, sqlx::postgres::PgRow> + Send + Unpin,
{
    match (business_date, as_of) {
        (Some(bd), Some(ts)) => {
            let date = parse_date(bd)?;
            let dt   = parse_dt(ts)?;
            let sql  = format!(
                "{base} WHERE {date_col} = $1 AND {in_col} <= $2 AND ({out_col} IS NULL OR {out_col} > $2)"
            );
            sqlx::query_as::<_, T>(&sql).bind(date).bind(dt).fetch_all(pool).await
        }
        (Some(bd), None) => {
            let date = parse_date(bd)?;
            let sql  = format!("{base} WHERE {date_col} = $1");
            sqlx::query_as::<_, T>(&sql).bind(date).fetch_all(pool).await
        }
        (None, Some(ts)) => {
            let dt  = parse_dt(ts)?;
            let sql = format!(
                "{base} WHERE {in_col} <= $1 AND ({out_col} IS NULL OR {out_col} > $1)"
            );
            sqlx::query_as::<_, T>(&sql).bind(dt).fetch_all(pool).await
        }
        (None, None) => sqlx::query_as::<_, T>(base).fetch_all(pool).await,
    }
    .map_err(|e| async_graphql::Error::new(e.to_string()))
}
{% endif %}
